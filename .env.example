PORT=8085
DATABASE_JDBC_URL=jdbc:postgresql://<supabase-host>:6543/postgres?sslmode=require
DATABASE_USERNAME=<supabase-username>
DATABASE_PASSWORD=<supabase-password>
DATABASE_DRIVER_CLASS_NAME=org.postgresql.Driver
SPRING_JPA_HIBERNATE_DDL_AUTO=update

JWT_SECRET=<jwt-secret-at-least-32-chars>
JWT_EXP_SECONDS=604800
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://bidmart.vercel.app
INTERNAL_SERVICE_TOKEN=<shared-internal-service-token>

WALLET_SERVICE_BASE_URL=https://<your-wallet-service>.herokuapp.com
